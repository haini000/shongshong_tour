{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://kdt-api-function.azurewebsites.net/api/$1"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}